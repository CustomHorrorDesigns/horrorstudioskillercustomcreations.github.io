        .product {
            background-color: #1c1c1c;
            border: 1px solid #e74c3c;
            padding: 1rem;
            width: 200px;
            text-align: center;
            border-radius: 5px;
        }
        .product img {
            width: 100%;
            border-radius: 5px;
        }
        a {
            color: #e74c3c;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        footer {
            margin-top: 2rem;
            padding: 1rem;
