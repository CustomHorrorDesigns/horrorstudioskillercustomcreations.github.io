            margin: 0;
            padding: 0;
        }
        header {
            background-color: #1c1c1c;
            padding: 2rem;
            border-bottom: 2px solid #e74c3c;
        }
        h1 {
            font-size: 2.5rem;
            margin: 0;
            color: #e74c3c;
        }
